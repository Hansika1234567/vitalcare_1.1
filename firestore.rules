rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    match /patient_caretaker/{relationId} {
      allow read, write: if request.auth != null;
    }

    match /patient_doctor/{relationId} {
      allow read, write: if request.auth != null;
    }

    match /vitals/{vitalId} {
      allow read, write: if request.auth != null;
    }

    match /appointments/{appointmentId} {
      allow read, write: if request.auth != null;
    }

    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
    }

    match /hospitals/{hospitalId} {
      allow read, write: if request.auth != null;
    }

    match /government_schemes/{schemeId} {
      allow read, write: if request.auth != null;
    }

    match /blood_donation/{donationId} {
      allow read, write: if request.auth != null;
    }

    match /agent_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    match /ai_insights/{insightId} {
      allow read, write: if request.auth != null;
    }

    match /emergency_events/{eventId} {
      allow read, write: if request.auth != null;
    }
  }
}
